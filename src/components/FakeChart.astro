---
const { type = 'bar' } = Astro.props;
const barData = [30, 50, 80, 45, 70];
const colors = ['#0984e3','#00b894','#e17055','#6c5ce7','#fdcb6e'];
---

<div class="chart-placeholder">
  {type === 'bar' && (
    <svg viewBox="0 0 400 200" width="100%" height="200" aria-label="Placeholder bar chart">
      {barData.map((val, i) => (
        <rect
          x={40 + i * 70}
          y={200 - val * 2}
          width={40}
          height={val * 2}
          fill={colors[i]}
          rx="4"
        />
      ))}
      <line x1="20" y1="180" x2="380" y2="180" stroke="#ddd" stroke-width="1" />
    </svg>
  )}
  {type === 'line' && (
    <svg viewBox="0 0 400 200" width="100%" height="200" aria-label="Placeholder line chart">
      <polyline
        points="20,180 100,140 180,60 260,100 340,40"
        fill="none"
        stroke="#0984e3"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <circle cx="20" cy="180" r="4" fill="#0984e3" />
      <circle cx="100" cy="140" r="4" fill="#0984e3" />
      <circle cx="180" cy="60" r="4" fill="#0984e3" />
      <circle cx="260" cy="100" r="4" fill="#0984e3" />
      <circle cx="340" cy="40" r="4" fill="#0984e3" />
    </svg>
  )}
  <div class="chart-caption">
    <slot name="caption">Placeholder chart – replace with real data</slot>
  </div>
</div>